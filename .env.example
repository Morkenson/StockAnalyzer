# Local Docker Postgres:
DATABASE_URL=postgresql://stockanalyzer:stockanalyzer@db:5432/stockanalyzer

# Or use any hosted PostgreSQL connection string, including Supabase's direct/session-pooler DB URL:
# DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Backend runtime
ENV=development
PORT=5000
# Comma-separated frontend origins allowed by backend CORS.
# Example: FRONTEND_ORIGINS=https://mork-wealth.zachary-mork-portfolio.dev,https://your-project.vercel.app
FRONTEND_ORIGINS=https://mork-wealth.zachary-mork-portfolio.dev

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
COOKIE_SECURE=false
# Use lax when the API is on the same site, e.g. app.yourdomain.com + api.yourdomain.com.
# Use none with COOKIE_SECURE=true only if frontend and API are on different sites.
COOKIE_SAMESITE=lax

# Email delivery (Resend). Required in production — sign-in OTPs and password
# reset links are only logged to the console in non-production environments.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Stock API
TWELVE_DATA_API_URL=https://api.twelvedata.com
TWELVE_DATA_API_KEY=

# SnapTrade
SNAPTRADE_API_URL=https://api.snaptrade.com/api/v1
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Trading safety switch. Only "live" actually submits buy/sell + recurring-buy orders to the
# brokerage. Any other value (default "test") simulates order placement so local/dev never
# moves real money. Set TRADING_MODE=live only in production once you've verified the flow.
TRADING_MODE=test

# Real estate listings (optional). Without a key, search uses built-in sample data.
# RentCast covers US listings; use "City, ST" locations to hit the live API.
RENTCAST_API_URL=https://api.rentcast.io/v1
RENTCAST_API_KEY=
# Hard cap on live RentCast calls per billing period; once reached, search
# serves sample data until the period resets. Counted in the database.
RENTCAST_MONTHLY_LIMIT=50
# Day of month the RentCast quota resets (your signup anniversary day).
RENTCAST_BILLING_DAY=1
# Days to cache a RentCast response. Repeat searches of the same city reuse the
# cached call (no quota spent) until it expires. Use the UI's Refresh to force a
# fresh pull.
RENTCAST_CACHE_DAYS=30

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
# Generate a stable app secret for token encryption; changing it makes stored Plaid tokens unreadable.
PLAID_TOKEN_ENCRYPTION_KEY=

# Optional frontend build override for deployed frontend builds.
# Docker local dev does not need this.
# API_BASE_URL=/api
